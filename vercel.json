{
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/coming-soon.html",
      "missing": [
        {
          "type": "query",
          "key": "preview",
          "value": "true"
        }
      ]
    },
    {
      "source": "/:path((?!coming-soon\\.html|css/|js/|data/|robots\\.txt|sitemap\\.xml|favicon\\.ico).*)",
      "destination": "/coming-soon.html",
      "missing": [
        {
          "type": "query",
          "key": "preview",
          "value": "true"
        }
      ]
    }
  ]
}
